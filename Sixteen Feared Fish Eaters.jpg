/* Reset and Base Styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Arial', 'Helvetica', sans-serif;
    line-height: 1.6;
    color: #eee;
    background-color: #121212;
}

header {
    background: #1f1f1f;
    padding: 1rem 5%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid #333;
}

.logo h1 {
    color: #c9a227; /* Gold accent */
    font-size: 1.8rem;
}

nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
}

nav a {
    color: #ddd;
    text-decoration: none;
    transition: color 0.3s;
}

nav a:hover {
    color: #c9a227;
}

.hero {
    background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('images/hero.jpg') center/cover no-repeat;
    height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
}

.hero-content {
    max-width: 800px;
    padding: 2rem;
}

.hero h2 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    text-shadow: 0 2px 10px rgba(0,0,0,0.8);
}

.hero p {
    font-size: 1.4rem;
    margin-bottom: 2rem;
}

.btn {
    background: #c9a227;
    color: #111;
    padding: 1rem 2.5rem;
    text-decoration: none;
    border-radius: 50px;
    font-weight: bold;
    transition: all 0.3s;
    display: inline-block;
}

.btn:hover {
    background: #e0b44a;
    transform: translateY(-3px);
}

.secondary {
    background: transparent;
    border: 2px solid #c9a227;
    color: #c9a227;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    padding: 4rem 5%;
}

.art-item {
    background: #1f1f1f;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 5px 15px rgba(0,0,0,0.5);
    transition: transform 0.3s;
}

.art-item:hover {
    transform: translateY(-10px);
}

.art-item img {
    width: 100%;
    height: 280px;
    object-fit: cover;
}

.art-item h3 {
    padding: 1rem 1rem 0.5rem;
    font-size: 1.3rem;
}

.art-item p {
    padding: 0 1rem 1rem;
    color: #aaa;
}

.art-item .price {
    font-weight: bold;
    color: #c9a227;
}

.add-to-cart {
    width: 100%;
    padding: 1rem;
    background: #333;
    color: white;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    transition: background 0.3s;
}

.add-to-cart:hover {
    background: #c9a227;
    color: #111;
}

section {
    padding: 4rem 5%;
}

h2 {
    text-align: center;
    margin-bottom: 3rem;
    font-size: 2.5rem;
    color: #c9a227;
}

footer {
    background: #0a0a0a;
    padding: 2rem;
    text-align: center;
    border-top: 1px solid #333;
}

footer a {
    color: #c9a227;
}

/* Responsive */
@media (max-width: 768px) {
    nav ul {
        gap: 1rem;
        font-size: 0.9rem;
    }
    .hero h2 {
        font-size: 2.5rem;
    }
}